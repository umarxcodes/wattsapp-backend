{
  "name": "WattsApp Backend",
  "type": "collection",
  "items": [
    {
      "name": "01 - Health Check",
      "request": { "method": "GET", "url": "http://localhost:5000/" }
    },
    {
      "name": "02 - Register",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/register",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923001112222\",\n  \"countryCode\": \"92\",\n  \"password\": \"TestPass1234\",\n  \"displayName\": \"Test User\"\n}"
        }
      }
    },
    {
      "name": "03 - Verify OTP",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/verify-otp",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923001112222\",\n  \"otp\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "04 - Login",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/login",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923001112222\",\n  \"countryCode\": \"92\",\n  \"password\": \"TestPass1234\"\n}"
        }
      }
    },
    {
      "name": "05 - Get Profile",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/v1/auth/profile",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    },
    {
      "name": "06 - Update Profile",
      "request": {
        "method": "PATCH",
        "url": "http://localhost:5000/api/v1/auth/profile",
        "headers": [
          { "name": "Authorization", "value": "Bearer <TOKEN>" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"displayName\": \"Updated Name\"\n}"
        }
      }
    },
    {
      "name": "07 - Create 2nd User",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/register",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923002223333\",\n  \"countryCode\": \"92\",\n  \"password\": \"TestPass1234\",\n  \"displayName\": \"Bob User\"\n}"
        }
      }
    },
    {
      "name": "08 - Verify 2nd User OTP",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/verify-otp",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923002223333\",\n  \"otp\": \"123456\"\n}"
        }
      }
    },
    {
      "name": "09 - Create Conversation",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/messages/conversations",
        "headers": [
          { "name": "Authorization", "value": "Bearer <TOKEN>" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"receiverId\": \"<BOB_USER_ID>\"\n}"
        }
      }
    },
    {
      "name": "10 - Get Conversations",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/v1/messages/conversations?page=1&limit=30",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    },
    {
      "name": "11 - Send Message",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/messages/<CONV_ID>",
        "headers": [
          { "name": "Authorization", "value": "Bearer <TOKEN>" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"text\": \"Hello Bob!\"\n}" }
      }
    },
    {
      "name": "12 - Get Messages",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/v1/messages/<CONV_ID>?cursor=0&limit=50",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    },
    {
      "name": "13 - Create Group",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/groups",
        "headers": [
          { "name": "Authorization", "value": "Bearer <TOKEN>" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test Group\",\n  \"participantIds\": [\"<ALICE_ID>\", \"<BOB_ID>\"],\n  \"isPublic\": true\n}"
        }
      }
    },
    {
      "name": "14 - Get Groups",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/v1/groups",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    },
    {
      "name": "15 - Block User",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/blocks",
        "headers": [
          { "name": "Authorization", "value": "Bearer <TOKEN>" },
          { "name": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"blockedUserId\": \"<BOB_ID>\"\n}"
        }
      }
    },
    {
      "name": "16 - Get Blocked Users",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/api/v1/blocks",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    },
    {
      "name": "17 - Unblock User",
      "request": {
        "method": "DELETE",
        "url": "http://localhost:5000/api/v1/blocks/<BOB_ID>",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    },
    {
      "name": "18 - Forgot Password",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/forgot-password",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923001112222\",\n  \"countryCode\": \"92\"\n}"
        }
      }
    },
    {
      "name": "19 - Reset Password",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/reset-password",
        "headers": [{ "name": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"phone\": \"+923001112222\",\n  \"countryCode\": \"92\",\n  \"otp\": \"123456\",\n  \"newPassword\": \"NewPass5678\"\n}"
        }
      }
    },
    {
      "name": "20 - Logout",
      "request": {
        "method": "POST",
        "url": "http://localhost:5000/api/v1/auth/logout",
        "headers": [{ "name": "Authorization", "value": "Bearer <TOKEN>" }]
      }
    }
  ]
}
